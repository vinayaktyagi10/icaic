con-boxed e-con e-parent\" data-id=\"e52bcd0\" data-element_type=\"container\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t\t\t<div class=\"elementor-element elementor-element-9fe0eb4 elementor-widget elementor-widget-heading\" data-id=\"9fe0eb4\" data-element_type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t<h3 class=\"elementor-heading-title elementor-size-default\">Workshop <br>on <br>\nFrom Draft to Print: Pre-Conference Workshop on LaTeX<\/h3>\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-10e6260 e-flex e-con-boxed e-con e-parent\" data-id=\"10e6260\" data-element_type=\"container\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t\t\t<div class=\"elementor-element elementor-element-5884c44 elementor-widget elementor-widget-text-editor\" data-id=\"5884c44\" data-element_type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t<style>\/*! elementor - v3.21.0 - 18-04-2024 *\/\n.elementor-widget-text-editor.elementor-drop-cap-view-stacked .elementor-drop-cap{background-color:#69727d;color:#fff}.elementor-widget-text-editor.elementor-drop-cap-view-framed .elementor-drop-cap{color:#69727d;border:3px solid;background-color:transparent}.elementor-widget-text-editor:not(.elementor-drop-cap-view-default) .elementor-drop-cap{margin-top:8px}.elementor-widget-text-editor:not(.elementor-drop-cap-view-default) .elementor-drop-cap-letter{width:1em;height:1em}.elementor-widget-text-editor .elementor-drop-cap{float:left;text-align:center;line-height:1;font-size:50px}.elementor-widget-text-editor .elementor-drop-cap-letter{display:inline-block}<\/style>\t\t\t\t<p><strong><span style=\"font-style: inherit;\">Workshop Date: September 16, 2025<\/span><\/strong><\/p><p>School of Computer Science and Engineering, Manipal University Jaipur, India is going\u00a0\u00a0 to\u00a0\u00a0 organize a one-day workshop on \u201cFrom Draft\u00a0 to Print: Pre-Conference Workshop\u00a0\u00a0 on\u00a0\u00a0 LaTeX\u201d under\u00a0\u00a0 the\u00a0\u00a0 aegis\u00a0\u00a0 of\u00a0\u00a0 First\u00a0\u00a0 International\u00a0\u00a0 Conference\u00a0\u00a0 on Artificial\u00a0\u00a0 Intelligence\u00a0\u00a0 &amp;\u00a0\u00a0 Computing (ICAIC-2025). The\u00a0\u00a0 aim of the workshop is to help participants to structure the scientific content in a proper manner and also discuss new tools of scientific publishing. Participants will be benefited from our eminent experts who have contributed greatly to the research society by publishing plenty of Research Articles\/ Books etc.<\/p><p>\u00a0<\/p><p><strong>Who should attend:\u00a0<\/strong>Students, Research Scholars, Faculty Members, Industry participants, etc<\/p><p>\u00a0<\/p><p><strong>Purpose\/ Benefits:<\/strong><\/p><ul><li>To learn the basics of research paper writing (How to prepare a manuscript, How to select a Journal for your work, Submission ethics, Reference management, etc.)<\/li><li>To enhance the paper writing skills.<\/li><li>To learn about various tools (LaTeX, Mendeley, Zotero, etc. ) that are effective in research paper writing .<\/li><li>Do&#8217;s and Don&#8217;t of research paper writing, etc.\u00a0<\/li><li>Inaugural free access to all the distinguished keynote speaker session.<\/li><\/ul>\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-cbfe24e e-flex e-con-boxed e-con e-parent\" data-id=\"cbfe24e\" data-element_type=\"container\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t<div class=\"elementor-element elementor-element-1c64bed e-con-full e-flex e-con e-child\" data-id=\"1c64bed\" data-element_type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-cfabc73 elementor-widget elementor-widget-text-editor\" data-id=\"cfabc73\" data-element_type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<d